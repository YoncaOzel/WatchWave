rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Users: any logged-in user can read profiles (for search & follow feature)
    match /users/{userId} {
      allow read: if request.auth != null;
      // Owner can do anything to their document
      allow write: if request.auth != null && request.auth.uid == userId;
      // Other logged-in users can update ONLY the followers field (for follow/unfollow)
      allow update: if request.auth != null
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['followers']);
    }

    // Lists: Watched, Favorites, and Watchlist are public for social features.
    match /users/{userId}/lists/{listType} {
      allow read: if request.auth != null && (listType == 'watched' || listType == 'favorites' || listType == 'watchlist' || request.auth.uid == userId);
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // User progress (episodes) - always private
    match /users/{userId}/progress/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Community reviews: any logged-in user can read, only the author can write
    match /reviews/{tmdbId}/communityReviews/{reviewId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == reviewId;
    }
  }
}
