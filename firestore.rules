rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Users: any logged-in user can read profiles (for search & follow feature)
    match /users/{userId} {
      allow read: if request.auth != null;
      // Owner can do anything to their document
      allow write: if request.auth != null && request.auth.uid == userId;
      // Other logged-in users can update ONLY the followers field (for follow/unfollow)
      allow update: if request.auth != null
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['followers']);
    }

    // User sub-collections (lists, progress) — only the owner can read/write
    match /users/{userId}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Community reviews: any logged-in user can read, only the author can write
    match /reviews/{tmdbId}/communityReviews/{reviewId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == reviewId;
    }
  }
}
